<% content_for :page_header do %>
  <div class="space-y-1">
    <h1 class="text-xl lg:text-3xl font-medium text-primary">Reports</h1>
    <p class="text-sm lg:text-base text-secondary">View your financial reports and analysis</p>
  </div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <%= link_to net_worth_reports_path, class: "group bg-container rounded-xl p-6 shadow-border-xs hover:shadow-xs transition-shadow" do %>
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-lg font-medium text-primary">Net Worth</h2>
        <p class="text-sm text-secondary">Track your total net worth over time</p>
      </div>
      <%= icon("trending-up", class: "text-secondary group-hover:text-primary transition-colors") %>
    </div>
  <% end %>

  <%= link_to balance_sheet_reports_path, class: "group bg-container rounded-xl p-6 shadow-border-xs hover:shadow-xs transition-shadow" do %>
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-lg font-medium text-primary">Balance Sheet</h2>
        <p class="text-sm text-secondary">See your assets and liabilities breakdown</p>
      </div>
      <%= icon("bar-chart-3", class: "text-secondary group-hover:text-primary transition-colors") %>
    </div>
  <% end %>

  <%= link_to cashflow_reports_path, class: "group bg-container rounded-xl p-6 shadow-border-xs hover:shadow-xs transition-shadow" do %>
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-lg font-medium text-primary">Cash Flow</h2>
        <p class="text-sm text-secondary">Understand your income and spending patterns</p>
      </div>
      <%= icon("activity", class: "text-secondary group-hover:text-primary transition-colors") %>
    </div>
  <% end %>

  <%= link_to net_income_reports_path, class: "group bg-container rounded-xl p-6 shadow-border-xs hover:shadow-xs transition-shadow" do %>
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-lg font-medium text-primary">Net Income</h2>
        <p class="text-sm text-secondary">Compare your income and expenses over time</p>
      </div>
      <%= icon("wallet", class: "text-secondary group-hover:text-primary transition-colors") %>
    </div>
  <% end %>
</div>
